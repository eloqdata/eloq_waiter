FROM ubuntu:24.04

RUN set -eux; \
    export DEBIAN_FRONTEND=noninteractive; \
    apt update; \
    apt install -y --no-install-recommends openssh-client redis-tools curl ca-certificates; \
    rm -rf /var/lib/apt/lists/*

RUN mkdir -p /root/.ssh && \
    echo "Host *\n\tStrictHostKeyChecking no\n\tUserKnownHostsFile /dev/null" > /root/.ssh/config

# SSH key, eloqctl binary, and test scripts are volume-mounted at runtime
WORKDIR /workspace

ENTRYPOINT ["/bin/bash"]
